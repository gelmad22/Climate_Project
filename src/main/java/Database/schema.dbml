// Ozon-Daten Analyse Backend
// Spring Boot + PostgreSQL
// Minimalmodell für Ozon-Messwerte aus JSON

Table stations {
  id integer [primary key, note: 'Station-ID aus der JSON-Datei, z.B. 1528']
}

Table ozone_measurements {
  id bigint [primary key, increment]

  station_id integer [not null]

  start_time timestamp [not null, note: 'Startzeit der Messung, z.B. 2016-01-01 22:00:00']
  end_time timestamp [not null, note: 'Endzeit der Messung']
  value_ug_m3 decimal(8,2) [not null, note: 'Ozonwert in µg/m³']

  created_at timestamp [note: 'Zeitpunkt, wann der Datensatz in die Datenbank gespeichert wurde']

  indexes {
    (station_id, start_time) [unique]
    (station_id, start_time)
    (station_id, value_ug_m3)
  }
}

Ref: ozone_measurements.station_id > stations.id

Records stations(id) {
  1528
}

Records ozone_measurements(id, station_id, start_time, end_time, value_ug_m3) {
  1, 1528, '2016-01-01 22:00:00', '2016-01-01 23:00:00', 21.00
  2, 1528, '2016-01-01 23:00:00', '2016-01-02 00:00:00', 31.00
}